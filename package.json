{
  "name": "@247b/dom-to-pptx",
  "version": "1.0.0",
  "description": "A client-side library that converts any HTML element into a fully editable PowerPoint slide.",
  "main": "dist/dom-to-pptx.cjs",
  "module": "dist/dom-to-pptx.mjs",
  "browser": "dist/dom-to-pptx.bundle.js",
  "exports": {
    ".": {
      "import": "./dist/dom-to-pptx.mjs",
      "require": "./dist/dom-to-pptx.cjs",
      "default": "./dist/dom-to-pptx.cjs"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npx rollup -c",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/247b/dom-to-pptx.git"
  },
  "keywords": [
    "pptx",
    "html-to-pptx",
    "powerpoint",
    "pptxgenjs",
    "dom"
  ],
  "author": "Atharva Dharmendra Jagtap <atharvaj321@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/247b/dom-to-pptx/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "fonteditor-core": "^2.6.3",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "opentype.js": "^1.3.4",
    "pako": "^2.1.0",
    "pptxgenjs": "^3.12.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "buffer": "^6.0.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "events": "^3.3.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.7.3",
    "process": "^0.11.10",
    "rollup": "^2.79.2",
    "rollup-plugin-polyfill-node": "^0.10.1",
    "stream-browserify": "^3.0.0",
    "util": "^0.12.5",
    "vitest": "^0.34.0"
  }
}
